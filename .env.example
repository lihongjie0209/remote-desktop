# Copy this file to .env and fill in your values before running docker-compose.

# Shared HMAC-SHA1 secret — must be the same on signal-server and turn-server.
TURN_SECRET=changeme

# Public IP address of this server (returned to clients as the TURN URI).
# Use your actual server IP, not 127.0.0.1, for remote clients to reach it.
PUBLIC_IP=127.0.0.1
